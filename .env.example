# =====================================================================
#  VILLA GRILL — Variáveis de ambiente
#  Copie este arquivo para ".env.local" e preencha os valores.
#  NUNCA comite o arquivo .env.local (ele tem chaves secretas).
# =====================================================================

# ---- Supabase (banco de dados + login do admin) --------------------
# Pegue em: Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# A "service_role" é SECRETA — só o servidor usa. Nunca colocar no navegador.
SUPABASE_SERVICE_ROLE_KEY=

# ---- IA da Lorena (OpenRouter) -------------------------------------
# Crie a chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Opcional (recomendado pela OpenRouter para identificar seu app):
OPENROUTER_SITE_URL=https://seu-dominio.com
OPENROUTER_APP_NAME=Villa Grill - Lorena

# ---- E-mail (envio dos avisos) -------------------------------------
# O Resend é só o "carteiro" que envia os e-mails. Os avisos chegam
# nos e-mails que você cadastrar no painel (seu Gmail, gerente, etc.).
# Crie a chave em: https://resend.com/api-keys
RESEND_API_KEY=
# Remetente técnico (aparece como "De:"). Use um domínio verificado no
# Resend, ou o sandbox onboarding@resend.dev para testes.
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Villa Grill

# ---- App ------------------------------------------------------------
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin
# Senha secreta que protege o relatório diário automático (invente uma longa).
CRON_SECRET=

# ---- Padrões --------------------------------------------------------
DEFAULT_RESTAURANT_SLUG=villa-grill
DEFAULT_TIMEZONE=America/Sao_Paulo
