# =====================================================================
#  VILLA GRILL — Variáveis de ambiente
#  Copie este arquivo para ".env.local" e preencha os valores.
#  NUNCA comite o arquivo .env.local (ele tem chaves secretas).
# =====================================================================

# ---- Supabase (banco de dados + login do admin) --------------------
# Pegue em: Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# A "service_role" é SECRETA — só o servidor usa. Nunca colocar no navegador.
SUPABASE_SERVICE_ROLE_KEY=

# ---- IA da Lorena (OpenRouter) -------------------------------------
# Crie a chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Opcional (recomendado pela OpenRouter para identificar seu app):
OPENROUTER_SITE_URL=https://seu-dominio.com
OPENROUTER_APP_NAME=Villa Grill - Lorena

# ---- E-mail (envio dos avisos) -------------------------------------
# Existem 2 formas. Use UMA delas:
#
# OPÇÃO A — SMTP (ex.: Gmail). Envia do SEU e-mail para QUALQUER destinatário,
#   de graça e SEM precisar de domínio. (Recomendado se você não tem domínio.)
#   Para Gmail: ative a verificação em 2 etapas e crie uma "Senha de app"
#   (Conta Google > Segurança > Senhas de app). Use essa senha em SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=seuemail@gmail.com
SMTP_PASS=senha-de-app-de-16-letras
#
# OPÇÃO B — Resend (precisa de domínio verificado para enviar a outros e-mails).
#   Crie a chave em: https://resend.com/api-keys
RESEND_API_KEY=
#
# Remetente que aparece no "De:". No Gmail, use o MESMO e-mail do SMTP_USER.
EMAIL_FROM=seuemail@gmail.com
EMAIL_FROM_NAME=Villa Grill

# ---- App ------------------------------------------------------------
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin
# Senha secreta que protege o relatório diário automático (invente uma longa).
CRON_SECRET=

# ---- Padrões --------------------------------------------------------
DEFAULT_RESTAURANT_SLUG=villa-grill
DEFAULT_TIMEZONE=America/Sao_Paulo
